TOURNAMENTS = read.csv(paste(CSV_PARSED_FOLDER, TOURNAMENTS_FILENAME, sep = "")) # READ ONLY
TOURNAMENTS$X = NULL
TOURNAMENTS_DATASET = data.frame()
for (tournament in TOURNAMENTS$slug) {
tournament_csv = read.csv(paste(CSV_PARSED_FOLDER, TOURNAMENTS_FOLDER, tournament, ".csv", sep = ""))
tournament_csv$X = NULL
tournament_csv["slug"] = tournament
TOURNAMENTS_DATASET = rbind(TOURNAMENTS_DATASET, tournament_csv) # vstack
}
archetypes = TOURNAMENTS_DATASET$archetype
archetypes = archetypes[!duplicated(archetypes)]
print(archetypes)
archetypes_info = data.frame(
"archetype" = archetypes,
"archetype_encoding" = 0:(length(archetypes) - 1),
"archetype_power_level" = 0
)
TOURNAMENTS_DATASET = merge(TOURNAMENTS_DATASET, archetypes_info, by = "archetype")
library(dplyr)
# Set the path to the directory containing your CSV files
path <- "./parsed/tournaments-TCG-3/decks/"  # replace with your actual path
# Get the list of CSV files in the directory
file_list <- list.files(path, pattern = "\\.csv$", full.names = TRUE)
# Read and merge all CSVs with an additional 'deck_id' column
DECKS_CSV <- lapply(file_list, function(file) {
df <- read.csv(file)
df$deck_id <- tools::file_path_sans_ext(basename(file)) # remove ".csv"
return(df)
}) %>%
bind_rows()  # Merge all into a single data frame
# View result
head(DECKS_CSV)
# Step 1: Keep only one archetype per deck_id (first occurrence)
tournament_archetypes <- TOURNAMENTS_DATASET %>%
filter(!is.na(deck_id)) %>%
distinct(deck_id, .keep_all = TRUE) %>%
dplyr::select(deck_id, archetype)
# Step 2: Join to add archetype to decks
decks_with_archetype <- DECKS_CSV %>%
left_join(tournament_archetypes, by = "deck_id")
View(decks_with_archetype)
# Step 1: Keep only one archetype per deck_id (first occurrence)
tournament_archetypes <- TOURNAMENTS_DATASET %>%
filter(!is.na(deck_id)) %>%
distinct(deck_id, .keep_all = TRUE) %>%
dplyr::select(deck_id, archetype)
# Step 2: Join to add archetype to decks
DECKS_CSV <- DECKS_CSV %>%
left_join(tournament_archetypes, by = "deck_id")
write.csv(DECKS_CSV, "DATASET-decks-TCG-3-six_months.csv")
TOURNAMENTS_FILENAME = "./datasets/DATASET-tournaments-TCG-3-six_months.csv"
TOURNAMENTS_DATASET = read.csv(TOURNAMENTS_FILENAME)
TOURNAMENTS_DATASET$X = NULL
tb = data.frame(table(TOURNAMENTS_DATASET$archetype)) # get frequence of each deck
library(ggplot2)
# Basic piechart
ggplot(tb, aes(x="", y=Freq, fill=Var1)) +
geom_bar(stat="identity", width=1, color="white") +
coord_polar("y", start=0) +
theme_void() # remove background, grid, numeric labels
winners = TOURNAMENTS_DATASET[TOURNAMENTS_DATASET$placement == "1",]
tb = data.frame(table(winners$archetype)) # get frequence of each deck
library(ggplot2)
# Basic piechart
ggplot(tb, aes(x="", y=Freq, fill=Var1)) +
geom_bar(stat="identity", width=1, color="white") +
coord_polar("y", start=0) +
theme_void() # remove background, grid, numeric labels
library(ggplot2)
ggplot(TOURNAMENTS_DATASET, aes(x = deck_cost, y = placement)) +
geom_point(color = "blue") +
labs(title = "placement vs deck cost",
x = "deck cost", y = "placement") +
geom_smooth(method = "lm", se = TRUE, color = "red") +
theme_minimal()
costo_medio_placement <- TOURNAMENTS_DATASET %>%
group_by(placement) %>%
summarise(costo_medio = mean(deck_cost, na.rm = TRUE)) %>%
arrange(placement)
print(costo_medio_placement)
#analisi 1: anova per vedere se esite una relazione
# Ipotesi nulla: il costo medio è lo stesso per tutti i piazzamenti.
# Se p < 0.05, rifiuti l’ipotesi nulla ⇒ almeno un gruppo ha un costo significativamente diverso.
anova_result <- aov(deck_cost ~ as.factor(placement), data = TOURNAMENTS_DATASET)
summary(anova_result)
# Da cosa dipende il piazzamento?
# Modello lineare: placement in funzione dell'archetipo
TOURNAMENTS_DATASET$placement <- as.numeric(as.character(TOURNAMENTS_DATASET$placement))
lm_model <- lm(placement ~ archetype, data = TOURNAMENTS_DATASET)
summary(lm_model)
plot(lm_model)
